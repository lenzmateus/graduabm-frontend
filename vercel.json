{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.protocolobravomike.com.br" }], "destination": "https://protocolobravomike.com.br/$1", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://graduabm-backend-production.up.railway.app/api/:path*" },
    { "source": "/dashboard", "destination": "/pbm-dashboard" },
    { "source": "/area-estudos", "destination": "/pbm-area-estudos" },
    { "source": "/selecao-legislacao", "destination": "/pbm-selecao-legislacao" },
    { "source": "/checkout-sucesso", "destination": "/pbm-checkout-sucesso" },
    { "source": "/questoes", "destination": "/pbm-questoes" },
    { "source": "/simulados", "destination": "/pbm-simulados" },
    { "source": "/simulado-prova", "destination": "/pbm-simulado-prova" },
    { "source": "/redefinir-senha", "destination": "/redefinir-senha" },
    { "source": "/ranking", "destination": "/pbm-ranking" },
    { "source": "/flashcards", "destination": "/pbm-flashcards" },
    { "source": "/regras", "destination": "/regras" },
    { "source": "/simulado-mensal", "destination": "/pbm-simulado-mensal" },
    { "source": "/simulado-mensal-ranking", "destination": "/pbm-simulado-mensal-ranking" },
    { "source": "/admin-simulados-mensais", "destination": "/admin-simulados-mensais" },
    { "source": "/admin-assinaturas", "destination": "/admin-assinaturas" },
    { "source": "/admin-relatorios", "destination": "/admin-relatorios" },
    { "source": "/gestor-login", "destination": "/gestor-login" },
    { "source": "/gestor-cadastro", "destination": "/gestor-cadastro" },
    { "source": "/gestor-painel", "destination": "/gestor-painel" },
    { "source": "/admin-cadastro", "destination": "/admin-cadastro" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src fonts.gstatic.com; connect-src 'self' https://graduabm-backend-production.up.railway.app https://cdn.jsdelivr.net; img-src 'self' data:" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
