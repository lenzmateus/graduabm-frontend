{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/area-estudos", "destination": "/graduabm-area-estudos.html" },
    { "source": "/selecao-legislacao", "destination": "/graduabm-selecao-legislacao.html" },
    { "source": "/checkout-sucesso", "destination": "/graduabm-checkout-sucesso.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
