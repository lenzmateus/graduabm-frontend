{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://graduabm-backend-production.up.railway.app/api/:path*" },
    { "source": "/dashboard", "destination": "/graduabm-dashboard" },
    { "source": "/area-estudos", "destination": "/graduabm-area-estudos" },
    { "source": "/selecao-legislacao", "destination": "/graduabm-selecao-legislacao" },
    { "source": "/checkout-sucesso", "destination": "/graduabm-checkout-sucesso" },
    { "source": "/questoes", "destination": "/graduabm-questoes" },
    { "source": "/simulados", "destination": "/graduabm-simulados" },
    { "source": "/simulado-prova", "destination": "/graduabm-simulado-prova" },
    { "source": "/redefinir-senha", "destination": "/redefinir-senha" },
    { "source": "/ranking", "destination": "/graduabm-ranking" },
    { "source": "/flashcards", "destination": "/graduabm-flashcards" },
    { "source": "/regras", "destination": "/regras" },
    { "source": "/simulado-mensal", "destination": "/graduabm-simulado-mensal" },
    { "source": "/simulado-mensal-ranking", "destination": "/graduabm-simulado-mensal-ranking" },
    { "source": "/admin-simulados-mensais", "destination": "/admin-simulados-mensais" },
    { "source": "/admin-assinaturas", "destination": "/admin-assinaturas" },
    { "source": "/gestor-login", "destination": "/gestor-login" },
    { "source": "/gestor-cadastro", "destination": "/gestor-cadastro" },
    { "source": "/gestor-painel", "destination": "/gestor-painel" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src fonts.gstatic.com; connect-src 'self' https://graduabm-backend-production.up.railway.app; img-src 'self' data:" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
